# ─── Supabase ────────────────────────────────────────────────────

# Prisma 连接 Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres"

# Supabase Auth (来源: Supabase Dashboard → Settings → API)
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# 客户端可见 (Next.js 必须以 NEXT_PUBLIC_ 前缀暴露给浏览器)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── CloudFlare R2 (来源: CloudFlare Dashboard → R2 → Manage API Tokens) ───

R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="lingyin-diary"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── 可选 ────────────────────────────────────────────────────────

# Sentry (错误监控)
# NEXT_PUBLIC_SENTRY_DSN="https://xxx.ingest.sentry.io/xxx"

# 域名 (Vercel 自动注入，本地无需设置)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
