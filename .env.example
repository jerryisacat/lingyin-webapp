# ─── Database ────────────────────────────────────────────────────

# Prisma 直连 PostgreSQL (Supabase / 任何 PG 实例)
DATABASE_URL="postgresql://postgres:***@db.xxx.supabase.co:5432/postgres"

# ─── Auth.js v5 ───────────────────────────────────────────────────

# JWT 签名密钥 (生成: openssl rand -hex 32)
AUTH_SECRET="your-64-char-hex-secret"

# Auth.js 基础 URL
# 开发: http://localhost:3000
# 生产: https://lingyin.app
AUTH_URL="http://localhost:3000"

# ─── API Key 加密 ─────────────────────────────────────────────────

# AES-256-GCM 加密密钥 (生成: openssl rand -hex 32)
API_KEY_ENCRYPTION_KEY="your-64-char-hex-key"

# ─── Resend 邮件服务 ──────────────────────────────────────────────

RESEND_API_KEY="re_..."

# 发件人地址 (需在 Resend 配置中验证)
EMAIL_FROM="noreply@lingyin.app"

# ─── CloudFlare R2 ────────────────────────────────────────────────

R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="lingyin-webapp"

# ─── Upstash Redis (速率限制) ──────────────────────────────────────

# Upstash Redis REST API URL，用于全局速率限制（@upstash/ratelimit）
# 开发: 可留空，速率限制将静默失败（仅限本地开发）
# 生产: 必须设置，否则所有速率限制端点将返回 500
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Vercel ───────────────────────────────────────────────────────

# Vercel 自动注入，本地无需设置
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"