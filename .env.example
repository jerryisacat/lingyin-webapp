# ─── Database ────────────────────────────────────────────────────

# Prisma 直连 PostgreSQL (Supabase / 任何 PG 实例)
# POSTGRES_PRISMA_URL 和 POSTGRES_URL_NON_POOLING 是 Vercel Supabase 集成自动注入的变量
# 本地开发时与 DATABASE_URL 保持一致即可
DATABASE_URL="postgresql://postgres:***@db.xxx.supabase.co:5432/postgres"
POSTGRES_PRISMA_URL="postgresql://postgres:***@db.xxx.supabase.co:5432/postgres"
POSTGRES_URL_NON_POOLING="postgresql://postgres:***@db.xxx.supabase.co:5432/postgres"

# ─── Auth.js v5 ───────────────────────────────────────────────────

# JWT 签名密钥 (生成: openssl rand -hex 32)
AUTH_SECRET="your-64-char-hex-secret"

# Auth.js 基础 URL
# 开发: http://localhost:3000
# 生产: https://lingyin.app
AUTH_URL="http://localhost:3000"

# ─── API Key 加密 ─────────────────────────────────────────────────

# AES-256-GCM 加密密钥 (生成: openssl rand -hex 32)
API_KEY_ENCRYPTION_KEY="your-64-char-hex-key"

# ─── Resend 邮件服务 ──────────────────────────────────────────────

RESEND_API_KEY="re_..."

# 发件人地址 (需在 Resend 配置中验证)
EMAIL_FROM="noreply@lingyin.app"

# ─── CloudFlare R2 ────────────────────────────────────────────────

R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="lingyin-webapp"

# ─── 健康检查 ──────────────────────────────────────────────────────

# 可选：设置后 /api/health 需要通过 ?token= 鉴权
HEALTH_SECRET="optional-shared-secret"

# ─── 速率限制 ──────────────────────────────────────────────────────

# 全局速率限制（@upstash/ratelimit + @upstash/redis）
# Vercel Dashboard → Storage → KV 或 Integrations → Upstash for Redis
#   自动注入 KV_REST_API_URL + KV_REST_API_TOKEN
# 本地开发: 可留空，速率限制将静默跳过
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ─── Vercel ───────────────────────────────────────────────────────

# Vercel 自动注入，本地无需设置
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"