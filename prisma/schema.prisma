generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  nickname      String?
  passwordHash  String
  image         String?
  tone          String    @default("warm")

  subscription     String?  @default("free")
  subscriptionId   String?
  subscribedAt     DateTime?
  subscriptionEnds DateTime?

  topUpBalanceUsd    Float  @default(0)
  tokenRolloverUsd   Float  @default(0)
  rolloverCalculated String?

  encryptionPasswordHash String?
  encryptionSalt         String?

  writingStyle Json @default("{\"perspective\": \"first_person\", \"persona\": \"yuanshao\"}")

  hasCompletedSetup Boolean @default(false)

  dailyEntryCount Int      @default(0)
  dailyEntryDate  DateTime?
  totalEntries    Int      @default(0)
  storageBytes    BigInt   @default(0)
  lastEntryAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries             Entry[]
  tokenUsages         TokenUsage[]
  tokenTopUps         TokenTopUp[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Entry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  title      String?
  tone       String   @default("warm")

  wordCount    Int      @default(0)
  preview      String?
  hasImages    Boolean  @default(false)
  imageCount   Int      @default(0)
  thumbnailUrl String?
  markdownPath String

  tags     String?
  location String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId, createdAt])
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String   @unique
  plan           String
  status         String
  stripeId       String?
  stripePriceId  String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  stripeInvoiceId String?
  amount         Int
  currency       String   @default("cny")
  status         String
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([userId])
}

model TokenUsage {
  id           String   @id @default(cuid())
  userId       String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TokenTopUp {
  id                    String   @id @default(cuid())
  userId                String
  amountUsd             Float
  priceCny              Int
  stripePaymentIntentId String?  @unique
  status                String   @default("pending")
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
